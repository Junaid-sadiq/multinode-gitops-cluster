# ============================================
# Networking Project .gitignore
# ============================================

# ===================
# Sensitive Files - NEVER COMMIT
# ===================
# Argo CD credentials
.argocd-credentials

# SSH Keys
*.pem
*.key
id_rsa*

# OpenStack credentials
terraform.tfvars
*.tfvars

# Environment variables
.env
.env.*

# ===================
# Terraform
# ===================
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ===================
# Ansible
# ===================
*.retry
ansible-reference-backup/inventory.ini

# ===================
# OS Generated Files
# ===================
# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.directory

# ===================
# IDEs and Editors
# ===================
# VS Code
.vscode/
*.code-workspace

# JetBrains (IntelliJ, PyCharm, etc)
.idea/
*.iml

# Vim
*.swp
*.swo
*~

# ===================
# Logs
# ===================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===================
# Temporary Files
# ===================
tmp/
temp/
*.tmp
*.bak
*.backup
