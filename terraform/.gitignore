# ============================================
# Terraform .gitignore
# ============================================
# Note: Main .gitignore is at project root
# This file provides Terraform-specific patterns

# Terraform files
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# Sensitive credentials - DO NOT COMMIT
terraform.tfvars
*.tfvars
*.pem
*.key
.env

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
